{
  "name": "photo-dedup",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node validate-env.mts && prisma generate && next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "format": "prettier --write src/ ./*.{mjs,ts,mts,md}",
    "format:check": "prettier --check src/ ./*.{mjs,ts,mts,md}",
    "lint": "eslint",
    "lint-staged": "lint-staged --concurrent=false",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest -c vitest-unit.config.ts",
    "test:unit:coverage": "vitest -c vitest-unit.config.ts --coverage",
    "test:ui": "vitest -c vitest-ui.config.ts --passWithNoTests",
    "test:ui:headless": "vitest -c vitest-ui.config.ts --browser.headless --passWithNoTests",
    "test:ui:coverage": "vitest -c vitest-ui.config.ts --coverage --passWithNoTests",
    "test:integration": "vitest -c vitest-integration.config.ts",
    "test:integration:coverage": "vitest -c vitest-integration.config.ts --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:ci": "start-server-and-test 'pnpm build && pnpm start' http://localhost:3000 'playwright test'",
    "postinstall": "playwright install --with-deps chromium",
    "prepare": "husky"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.576.0",
    "mime-types": "^3.0.2",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@next/env": "^16.1.6",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@testcontainers/postgresql": "^11.12.0",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^25.3.3",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9.39.3",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "msw": "^2.12.10",
    "pg": "^8.19.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "prisma": "^7.4.2",
    "start-server-and-test": "^2.1.5",
    "tailwindcss": "^4.2.1",
    "testcontainers": "^11.12.0",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vercel": "^50.26.1",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "vitest-browser-react": "^2.0.5"
  }
}
